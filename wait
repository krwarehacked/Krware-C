local target_container = (gethui and gethui()) or CoreGui
local espsettings = {color = Color3.fromRGB(255, 50, 50), outline = Color3.fromRGB(0, 0, 0), team_check = false, enabled = false}
local espStarted = false

local function handle_plr(v)
   local function inject(char)
      if not char then return end
      local tag = "hx_" .. v.UserId
      local h = target_container:FindFirstChild(tag) or Instance.new("Highlight")
      h.Name = tag h.Adornee = char h.FillColor = espsettings.color h.OutlineColor = espsettings.outline
      h.FillTransparency = 0.45 h.OutlineTransparency = 0 h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop h.Parent = target_container
   end
   v.CharacterAdded:Connect(inject)
   if v.Character then inject(v.Character) end
end

local function startESP()
   if espStarted then return end
   espStarted = true
   for _, v in next, Players:GetPlayers() do if v ~= plr then handle_plr(v) end end
   Players.PlayerAdded:Connect(handle_plr)
   game:GetService("RunService").RenderStepped:Connect(function()
      for _, v in next, Players:GetPlayers() do
         local tag = "hx_" .. v.UserId
         local obj = target_container:FindFirstChild(tag)
         if obj then
            if not espsettings.enabled or v == plr or not v.Character then obj.Enabled = false
            else obj.Enabled = true end
         end
      end
   end)
end

